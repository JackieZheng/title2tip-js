{
    "name":  "@jackiezhengchina/title2tip",
    "version":  "1.0.2",
    "description":  "Custom HTML title tooltip plugin with auto-positioning, large image support, and full customization",
    "main":  "dist/title2tip.min.js",
    "module":  "src/title2tip.js",
    "files":  [
                  "src",
                  "dist"
              ],
    "scripts":  {
                    "build":  "npx mkdirp dist \u0026\u0026 uglifyjs src/title2tip.js -o dist/title2tip.min.js -c -m"
                },
    "keywords":  [
                     "tooltip",
                     "title",
                     "hover",
                     "popup",
                     "image-tooltip",
                     "position-adaptive"
                 ],
    "author":  "JackieZheng",
    "license":  "MIT",
    "repository":  {
                       "type":  "git",
                       "url":  "git+https://github.com/JackieZheng/title2tip-js.git"
                   },
    "publishConfig":  {
                          "registry":  "https://registry.npmjs.org"
                      },
    "devDependencies":  {
                            "uglify-js":  "^3.17.0",
                            "mkdirp":  "^3.0.1"
                        }
}
